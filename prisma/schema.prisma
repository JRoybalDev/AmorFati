generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PostType {
  IMAGE
  TEXT
  FILM
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  username  String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts     Post[]
}

model Post {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  type      PostType
  title     String?
  content   String?  @db.Text
  imageUrl  String?  @map("image_url") // Used for ImagePost image or FilmPost poster
  link      String?  // Used for FilmPost db url

  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
}
