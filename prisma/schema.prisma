generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  username String @unique
}

model ImagePost {
  // Essential Fields
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  // Specific Fields
  imageUrl  String   @map("image_url")
}

model TextPost {
  // Essential Fields
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  // Specific Fields
  title     String
  date      DateTime
  content   String   @db.Text
}

model FilmPost {
  // Essential Fields
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  // Specific Fields
  title         String
  content       String   @db.Text
  filmPosterUrl String   @map("film_poster_url")
  filmDbUrl     String   @map("film_db_url")
}
